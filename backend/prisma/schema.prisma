generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  phoneNumber  String?  @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  workoutLogs  WorkoutLog[]
  cardioLogs   CardioLog[]
  foodLogs     FoodLog[]
  waterLogs    WaterLog[]
  weightLogs   WeightLog[]
  aiChats      AIChat[]
  orders       Order[]
  reviews      Review[]
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  photoUrl      String?
  age           Int?
  gender        String?
  height        Float?   // in cm
  currentWeight Float?   // in kg
  desiredWeight Float?   // in kg
  activityLevel String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Exercise {
  id                   String   @id @default(uuid())
  name                 String
  photoUrl             String?
  gifUrl               String?
  difficulty           String?
  category             String?  // Push/Pull/Legs
  muscleGroup          String?
  equipmentRequired    String?
  caloriesBurnedPerMin Float?
  instructions         String?
  commonMistakes       String?
  videoUrl             String?
  
  // Vector embedding for RAG
  embedding            Unsupported("vector(768)")?
  
  workoutSets          WorkoutSet[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model WorkoutLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  notes     String?
  sets      WorkoutSet[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkoutSet {
  id           String     @id @default(uuid())
  workoutLogId String
  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])
  sets         Int
  reps         Int
  weight       Float      // in kg
  restTime     Int        // in seconds
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CardioLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // Treadmill, Running, etc.
  duration  Int      // in minutes
  speed     Float?
  incline   Float?
  calories  Float?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodItem {
  id           String   @id @default(uuid())
  name         String
  servingSize  String
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  isCustom     Boolean  @default(false)
  approved     Boolean  @default(true)
  foodLogs     FoodLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FoodLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  foodItemId String
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id])
  quantity   Float
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WaterLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int      // in ml
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weight    Float    // in kg
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIChat {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isUser    Boolean
  createdAt DateTime @default(now())
}

model MarketplaceProduct {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  category    String
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  productId  String
  product    MarketplaceProduct @relation(fields: [productId], references: [id])
  quantity   Int
  totalPrice Float
  status     String             @default("PENDING")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model Gym {
  id          String   @id @default(uuid())
  name        String
  address     String
  lat         Float
  lng         Float
  rating      Float?
  contact     String?
  openHours   String?
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
